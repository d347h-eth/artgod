{
    "name": "@artgod/frontend",
    "private": true,
    "version": "0.0.1-pre-alpha.7",
    "type": "module",
    "scripts": {
        "dev": "vite dev --host 127.0.0.1 --port 5173 --strictPort",
        "build": "svelte-kit sync && vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "test:unit": "vitest",
        "test": "vitest --run",
        "test:preview:attached": "playwright test -c playwright.attached.config.ts",
        "test:preview:attached:headed": "playwright test -c playwright.attached.config.ts --headed",
        "test:preview:attached:artifacts": "ARTGOD_E2E_PERSIST_SUCCESS_ARTIFACTS=1 playwright test -c playwright.attached.config.ts",
        "test:preview:attached:headed:artifacts": "ARTGOD_E2E_PERSIST_SUCCESS_ARTIFACTS=1 playwright test -c playwright.attached.config.ts --headed"
    },
    "dependencies": {
        "@artgod/shared": "workspace:*",
        "@tauri-apps/api": "^2.8.0"
    },
    "devDependencies": {
        "@eslint/compat": "^1.2.5",
        "@eslint/js": "^9.18.0",
        "@sveltejs/adapter-node": "^5.2.12",
        "@sveltejs/adapter-static": "^3.0.9",
        "@sveltejs/kit": "^2.16.0",
        "@sveltejs/vite-plugin-svelte": "^5.0.0",
        "@tailwindcss/forms": "^0.5.9",
        "@tailwindcss/typography": "^0.5.15",
        "@tailwindcss/vite": "^4.0.0",
        "@vitest/browser": "^3.2.3",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-svelte": "^3.0.0",
        "globals": "^16.0.0",
        "playwright": "^1.53.0",
        "svelte": "^5.0.0",
        "svelte-check": "^4.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.20.0",
        "vite": "^6.2.6",
        "vitest": "^3.2.3",
        "vitest-browser-svelte": "^0.1.0"
    }
}
