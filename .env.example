# Indexer runtime
ARTGOD_DB_PATH=database/sqlite/main/db
CHAIN_ID=1
RPC_URL=http://127.0.0.1:8545
# RPC_BACKFILL_URL=
# RPC_WS_URL=ws://127.0.0.1:8546
WETH_ADDRESS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2
NATS_URL=nats://127.0.0.1:4222
NATS_STREAM_PREFIX=artgod
REORG_DEPTH=32
BACKFILL_BATCH_SIZE=50
LOG_CHUNK_SIZE=2000
CACHE_MAX_ENTRIES=5000
CACHE_TTL_MS=30000

# JSON array of target collections
# Example: [{"id":"terraforms","address":"0x4E1f41613c9084FdB9E34E11fAE9412427480e56","deploymentBlock":13823015}]
TARGET_COLLECTIONS=[]

# Offchain OpenSea stream (fixture replay mode)
OPENSEA_STREAM_MODE=fixtures
OPENSEA_FIXTURES_DIR=indexer/tests/fixtures/opensea-event-payloads
OPENSEA_FIXTURE_DELAY_MS=0
