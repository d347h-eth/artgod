BACKEND_ALLOWED_HOSTS=127.0.0.1,localhost,::1
BACKEND_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:5173,http://localhost:5173,http://tauri.localhost,tauri://localhost
BACKEND_CSRF_COOKIE_SECURE=false
BACKEND_QUERY_CACHE_PROVIDER=disabled
BACKEND_QUERY_CACHE_MAX_ENTRIES=500
BACKEND_QUERY_CACHE_COLLECTION_DETAIL_DEFAULT_TTL_MS=10000
