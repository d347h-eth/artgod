# Generated from config/settings.manifest.toml.
# Do not edit directly; run `yarn config:generate`.

# Chain and RPC
# SQLite database file path; desktop relative paths resolve from app data.
ARTGOD_DB_PATH=database/sqlite/main/db
# EVM chain ID used by backend, indexer, and trading runtimes.
CHAIN_ID=1
# Weighted Ethereum HTTP JSON-RPC endpoints used by backend, indexer, and trading runtimes.
RPC_URL_LIST=
# Optional weighted HTTP JSON-RPC endpoints used only for historical backfill jobs.
RPC_BACKFILL_URL_LIST=
# Optional weighted WebSocket JSON-RPC endpoints for faster new-block detection.
RPC_WS_URL_LIST=
# Per-attempt timeout for HTTP JSON-RPC requests.
RPC_HTTP_REQUEST_TIMEOUT_MS=10000
# Maximum HTTP JSON-RPC retry attempts before the request fails.
RPC_RETRY_MAX_ATTEMPTS=10
# Initial backoff delay between HTTP JSON-RPC retry attempts.
RPC_RETRY_BASE_DELAY_MS=500
# Maximum backoff delay between HTTP JSON-RPC retry attempts.
RPC_RETRY_MAX_DELAY_MS=10000
# Maximum HTTP JSON-RPC requests per endpoint each second; 0 disables throttling.
RPC_RATE_LIMIT_REQUESTS_PER_SECOND=5
# Burst capacity for each endpoint's HTTP JSON-RPC rate limiter.
RPC_RATE_LIMIT_BURST=5
# Consecutive endpoint failures before the HTTP JSON-RPC circuit opens.
RPC_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# How long an unhealthy HTTP JSON-RPC endpoint is paused before trial requests resume.
RPC_CIRCUIT_BREAKER_OPEN_MS=5000
# Trial request count allowed while a paused HTTP JSON-RPC endpoint is recovering.
RPC_CIRCUIT_BREAKER_HALF_OPEN_MAX_REQUESTS=2
# Canonical WETH contract address used for bid validation and bidding wallet checks.
WETH_ADDRESS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2
# Seaport ConduitController contract address used to resolve conduit approvals.
SEAPORT_CONDUIT_CONTROLLER=0x00000000f9490004c11cef243f5400493c00ad63

# Backend
# Network interface the backend listens on; keep localhost for desktop and local use.
BACKEND_HOST=127.0.0.1
# Port for the local backend API and userland web server.
BACKEND_PORT=42710
# Comma-separated Host headers accepted by the backend.
BACKEND_ALLOWED_HOSTS=127.0.0.1,localhost,::1
# Comma-separated browser origins allowed to make authenticated backend requests.
BACKEND_ALLOWED_ORIGINS=http://127.0.0.1:42710,http://localhost:42710,http://127.0.0.1:42701,http://localhost:42701,http://tauri.localhost,tauri://localhost
# Requires the CSRF cookie to be sent only over HTTPS; enable for public HTTPS deploys.
BACKEND_CSRF_COOKIE_SECURE=false
# How often the backend refreshes cached public blockspace data.
BACKEND_PUBLIC_BLOCKSPACE_CACHE_REFRESH_MS=60000

# Backend Cache
# Selects the backend read-query cache; memory helps public read-heavy pages, while disabled keeps reads uncached.
BACKEND_QUERY_CACHE_PROVIDER=disabled
# Maximum token-preview responses kept in the backend memory cache.
BACKEND_QUERY_CACHE_TOKEN_PREVIEW_MAX_ENTRIES=250
# How long cached token previews are served as fresh before background refresh is considered.
BACKEND_QUERY_CACHE_TOKEN_PREVIEW_FRESH_MS=600000
# How long cached token previews may be served while a replacement is warming.
BACKEND_QUERY_CACHE_TOKEN_PREVIEW_STALE_MS=1200000
# How many token previews the backend warms in parallel after cached collection refreshes.
BACKEND_QUERY_CACHE_TOKEN_PREVIEW_WARMUP_CONCURRENCY=3
# How often the backend refreshes the cached public collection page.
BACKEND_PUBLIC_COLLECTION_CACHE_REFRESH_MS=30000
# How often the backend warms token previews for the cached public collection page.
BACKEND_PUBLIC_COLLECTION_PREVIEW_WARM_REFRESH_MS=600000

# Backend Observability
# Enables the backend Prometheus metrics endpoint.
BACKEND_METRICS_ENABLED=false
# Network interface for the backend metrics endpoint.
BACKEND_METRICS_HOST=0.0.0.0
# Port for the backend Prometheus metrics endpoint.
BACKEND_METRICS_PORT=42740
# Enables backend tracing and profiling exporters.
BACKEND_APM_ENABLED=false
# Service namespace used to group backend APM signals.
BACKEND_APM_SERVICE_NAMESPACE=artgod.backend
# Optional backend-specific OTLP HTTP trace endpoint; blank uses the shared observability endpoint.
BACKEND_APM_OTLP_HTTP_URL=
# Optional backend-specific Pyroscope profiling endpoint; blank uses the shared observability endpoint.
BACKEND_APM_PYROSCOPE_URL=
# Links backend span context to profiling samples when tracing and profiling are enabled.
BACKEND_APM_SPAN_PROFILES_ENABLED=true
# Exports backend traces to the configured OTLP endpoint when APM is enabled.
BACKEND_APM_TRACES_ENABLED=true
# Exports backend CPU profiles to the configured Pyroscope endpoint when APM is enabled.
BACKEND_APM_PROFILES_ENABLED=true

# Public Deployment
# Public browser origin for the backend API in hosted web deployments.
PUBLIC_BACKEND_ORIGIN=http://127.0.0.1:42710
# Private service origin used by server-side frontend code to reach the backend.
INTERNAL_BACKEND_ORIGIN=
# Selects standard multi-collection UI or public single-collection mode for hosted builds.
PUBLIC_APP_DEPLOYMENT_MODE=standard
# Chain reference used by public single-collection mode.
PUBLIC_APP_CHAIN_REF=
# Collection reference used by public single-collection mode.
PUBLIC_APP_COLLECTION_REF=

# Desktop Runtime
# Directory containing the built userland UI served by the backend.
USERLAND_UI_DIST_DIR=
# Desktop resource directory containing bundled runtime artifacts.
DESKTOP_RUNTIME_RESOURCES_DIR=runtime
# Optional Node executable path; blank uses the Node bundled with desktop resources.
DESKTOP_NODE_BIN=
# Optional NATS server executable path; blank uses the NATS binary bundled with desktop resources.
DESKTOP_NATS_BINARY_PATH=
# Optional Yarn PnP CommonJS hook path for bundled Node runtimes.
DESKTOP_NODE_PNP_CJS=
# Optional Yarn PnP ESM loader path for bundled Node runtimes.
DESKTOP_NODE_PNP_LOADER=
# Delay before the desktop supervisor restarts the core runtime after a crash.
DESKTOP_RESTART_BACKOFF_MS=1500
# How long desktop app-data log files are retained; logs rotate by UTC day.
DESKTOP_LOG_RETENTION_HOURS=48
# Directory where desktop stores encrypted wallet keystore files.
DESKTOP_WALLET_STORE_DIR=wallets
# How long the core runtime must stay healthy before Admin shows a bot unlock prompt.
DESKTOP_BOT_UNLOCK_STABILIZATION_DELAY_MS=5000

# Queue
# NATS server URL used by backend, indexer, and trading runtimes for queues.
NATS_URL=nats://127.0.0.1:42720
# Prefix added to NATS streams and durable queue names for this ArtGod instance.
NATS_STREAM_PREFIX=artgod

# Indexer
# Maximum entries in the indexer in-memory helper cache.
CACHE_MAX_ENTRIES=5000
# How long indexer in-memory helper cache entries remain valid.
CACHE_TTL_MS=30000
# Stores raw OpenSea observations for audit/debugging; keep disabled unless you need source payload history.
OFFCHAIN_PERSIST_RAW_OBSERVATIONS=false
# Stores large raw metadata/order debug payloads in SQLite; keep disabled unless debugging normalization.
PERSIST_RAW_DEBUG_PAYLOADS=false
# HTTP origin used to resolve ipfs:// token metadata and media URLs.
COMMON_IPFS_GATEWAY_ORIGIN=https://ipfs.io
# Token-image cache directory; blank stores cached images beside the SQLite database.
COMMON_MEDIA_CACHE_DIR=
# Per-attempt timeout for ordinary metadata and media HTTP fetches.
COMMON_HTTP_FETCH_TIMEOUT_MS=10000
# Maximum attempts for ordinary metadata and media HTTP fetches.
COMMON_HTTP_FETCH_RETRY_MAX_ATTEMPTS=3
# Initial exponential-backoff delay for ordinary metadata and media HTTP fetch retries.
COMMON_HTTP_FETCH_RETRY_BASE_DELAY_MS=250
# Maximum exponential-backoff delay for ordinary metadata and media HTTP fetch retries.
COMMON_HTTP_FETCH_RETRY_MAX_DELAY_MS=2000
# Number of recent blocks kept protected from finality assumptions during reorg checks.
REORG_DEPTH=32
# Block range size fetched by each backfill sync job.
BACKFILL_BATCH_SIZE=10
# Number of safe historical backfill jobs the sync worker may process in parallel.
BACKFILL_WORKER_COUNT=1
# Maximum block span fetched per getLogs chunk during sync.
LOG_CHUNK_SIZE=2000
# Token count per ownership snapshot task during collection bootstrap.
BOOTSTRAP_SNAPSHOT_BATCH_SIZE=200
# Token count per metadata snapshot task during collection bootstrap.
BOOTSTRAP_METADATA_BATCH_SIZE=200
# Number of metadata snapshot tasks processed in parallel by each bootstrap worker lease.
BOOTSTRAP_METADATA_CONCURRENCY=8
# How often bootstrap workers poll for metadata tasks when a metadata step is active.
BOOTSTRAP_METADATA_PROCESS_POLL_MS=5000
# Minimum delay between bootstrap scheduler polls when work is available.
BOOTSTRAP_SCHEDULER_POLL_MIN_MS=250
# Maximum delay between bootstrap scheduler polls when waiting for work.
BOOTSTRAP_SCHEDULER_POLL_MAX_MS=5000
# How long a bootstrap step lease lasts before another worker may recover it.
BOOTSTRAP_STEP_LEASE_MS=60000
# How long a bootstrap step can make no progress before it is treated as stale.
BOOTSTRAP_STEP_PROGRESS_STALE_MS=1800000
# Number of collection-extension artifact tasks the worker may process in parallel.
BOOTSTRAP_COLLECTION_EXTENSION_ARTIFACT_CONCURRENCY=2
# Lease duration for one collection-extension artifact task while it is being rendered or fetched.
BOOTSTRAP_COLLECTION_EXTENSION_ARTIFACT_TASK_LEASE_MS=60000
# Maximum retry attempts for failed bootstrap metadata tasks.
BOOTSTRAP_METADATA_RETRY_MAX_ATTEMPTS=3
# Initial backoff delay before retrying failed bootstrap metadata tasks.
BOOTSTRAP_METADATA_RETRY_BASE_DELAY_MS=100
# Maximum backoff delay before retrying failed bootstrap metadata tasks.
BOOTSTRAP_METADATA_RETRY_MAX_DELAY_MS=1000
# Token count per bootstrap image-cache task.
BOOTSTRAP_IMAGE_CACHE_BATCH_SIZE=50
# Number of bootstrap image-cache tasks processed in parallel.
BOOTSTRAP_IMAGE_CACHE_CONCURRENCY=4
# Maximum remote image byte size accepted for bootstrap image caching.
BOOTSTRAP_IMAGE_CACHE_MAX_SOURCE_BYTES=26214400
# Token range size processed by each metadata refresh chunk.
METADATA_REFRESH_RANGE_CHUNK_SIZE=200

# Indexer Observability
# Shared OTLP HTTP trace endpoint used when workspace-specific trace endpoints are blank.
OBSERVABILITY_OTLP_HTTP_URL=http://127.0.0.1:42732/v1/traces
# Shared Pyroscope profiling endpoint used when workspace-specific profile endpoints are blank.
OBSERVABILITY_PYROSCOPE_URL=http://127.0.0.1:42733
# Enables tracing and profiling exporters for indexer and OpenSea workers.
INDEXER_APM_ENABLED=false
# Service namespace used to group indexer APM signals.
INDEXER_APM_SERVICE_NAMESPACE=artgod.indexer
# Optional indexer-specific OTLP HTTP trace endpoint; blank uses the shared observability endpoint.
INDEXER_APM_OTLP_HTTP_URL=
# Optional indexer-specific Pyroscope profiling endpoint; blank uses the shared observability endpoint.
INDEXER_APM_PYROSCOPE_URL=
# Links indexer span context to profiling samples when tracing and profiling are enabled.
INDEXER_APM_SPAN_PROFILES_ENABLED=true
# Exports indexer traces to the configured OTLP endpoint when APM is enabled.
INDEXER_APM_TRACES_ENABLED=true
# Exports indexer CPU profiles to the configured Pyroscope endpoint when APM is enabled.
INDEXER_APM_PROFILES_ENABLED=true
# Enables Prometheus metrics endpoints for indexer and OpenSea workers.
INDEXER_METRICS_ENABLED=false
# Network interface for indexer metrics endpoints.
INDEXER_METRICS_HOST=0.0.0.0
# Prometheus metrics port for the scheduler worker.
INDEXER_METRICS_PORT_SCHEDULER_WORKER=42741
# Prometheus metrics port for the sync worker.
INDEXER_METRICS_PORT_SYNC_WORKER=42742
# Prometheus metrics port for the reorg worker.
INDEXER_METRICS_PORT_REORG_WORKER=42743
# Prometheus metrics port for the domain worker.
INDEXER_METRICS_PORT_DOMAIN_WORKER=42744
# Prometheus metrics port for the offchain ingest worker.
INDEXER_METRICS_PORT_OFFCHAIN_INGEST_WORKER=42745
# Prometheus metrics port for the OpenSea stream worker.
INDEXER_METRICS_PORT_OPENSEA_STREAM_WORKER=42746
# Prometheus metrics port for the collection bootstrap worker.
INDEXER_METRICS_PORT_BOOTSTRAP_WORKER=42747
# Prometheus metrics port for the dead-letter worker.
INDEXER_METRICS_PORT_DEAD_LETTER_WORKER=42748
# Prometheus metrics port for the OpenSea bootstrap worker.
INDEXER_METRICS_PORT_OPENSEA_BOOTSTRAP_WORKER=42749
# Prometheus metrics port for the OpenSea reconcile worker.
INDEXER_METRICS_PORT_OPENSEA_RECONCILE_WORKER=42750
# Prometheus metrics port for the OpenSea reconcile scheduler worker.
INDEXER_METRICS_PORT_OPENSEA_RECONCILE_SCHEDULER_WORKER=42751
# Prometheus metrics port for the collection-extension worker.
INDEXER_METRICS_PORT_COLLECTION_EXTENSION_WORKER=42752

# OpenSea
# Controls whether OpenSea workers and OpenSea-dependent bot starts are automatic, required, or disabled.
OPENSEA_INTEGRATION_MODE=auto
# OpenSea API key for indexer order snapshots, streams, and reconcile workers.
OPENSEA_API_KEY=
# OpenSea orderbook page size for snapshot and reconcile fetches.
OPENSEA_SNAPSHOT_PAGE_SIZE=100
# How often OpenSea reconcile workers refresh orderbooks for live collections.
OPENSEA_RECONCILE_INTERVAL_MS=900000
# Age after which OpenSea orderbook state is considered stale enough to reconcile on startup.
OPENSEA_STALE_START_THRESHOLD_MS=1800000
# How often OpenSea stream workers check for collection subscription changes.
OPENSEA_STREAM_SUBSCRIPTION_POLL_MS=5000
# How many times OpenSea HTTP calls may be attempted before the operation fails.
OPENSEA_HTTP_RETRY_MAX_ATTEMPTS=5
# Initial delay before retrying a failed OpenSea HTTP call.
OPENSEA_HTTP_RETRY_BASE_DELAY_MS=500
# Maximum delay between retries for a failed OpenSea HTTP call.
OPENSEA_HTTP_RETRY_MAX_DELAY_MS=10000
# Randomizes OpenSea HTTP retry delays so repeated failures do not all retry at the same instant.
OPENSEA_HTTP_RETRY_JITTER_RATIO=0.2
# Maximum OpenSea GET requests the app may start immediately.
OPENSEA_RATE_LIMIT_GET_MAX=4
# How quickly OpenSea GET request capacity refills while the app is running.
OPENSEA_RATE_LIMIT_GET_REFILL_PER_SECOND=1
# Maximum OpenSea POST requests the app may start immediately.
OPENSEA_RATE_LIMIT_POST_MAX=2
# How quickly OpenSea POST request capacity refills while the app is running.
OPENSEA_RATE_LIMIT_POST_REFILL_PER_SECOND=0.5

# Trading OpenSea
# OpenSea API key for the bidding bot stream lane; use a separate key when available.
OPENSEA_STREAM_SECRET_KEY=
# OpenSea API key for bidding order placement and cancellation; use a separate key when available.
OPENSEA_BIDDING_SECRET_KEY=
# OpenSea API key for bidding collection-offer snapshots; use a separate key when available.
OPENSEA_SNAPSHOT_SECRET_KEY=

# Trading Observability
# Enables the bidding bot Prometheus metrics endpoint.
TRADING_METRICS_ENABLED=false
# Network interface for trading metrics endpoints.
TRADING_METRICS_HOST=0.0.0.0
# Prometheus metrics port for the bidding bot runtime.
TRADING_METRICS_PORT_BIDDING_BOT=42753

# Bidding
# Enables wallet-bound bidding runtime startup when required OpenSea bot keys are configured.
BIDDING_ENABLED=true
# Runs the bidding bot without placing or cancelling live orders.
BIDDING_DRY_RUN=false
# Startup WETH approval target for OpenSea bidding, in Ether units; 0 skips approval.
BIDDING_WETH_ALLOWANCE_ETH=0
# Minimum EIP-1559 priority fee for bidding transactions, in gwei.
BIDDING_TX_MIN_PRIORITY_FEE_GWEI=0.1
# Number of recent blocks sampled when estimating bidding priority fees.
BIDDING_TX_FEE_HISTORY_BLOCKS=20
# Reward percentile used when estimating bidding priority fees from fee history.
BIDDING_TX_FEE_HISTORY_REWARD_PERCENTILE=70
# Multiplier applied to the current base fee when setting bidding max fees.
BIDDING_TX_BASE_FEE_MULTIPLIER=1.25
# Upper bound for bidding transaction max fee, in gwei.
BIDDING_TX_MAX_FEE_GWEI=10
# Policy for starting the bidding bot when the wallet already has pending transactions.
BIDDING_TX_PENDING_NONCE_POLICY=fail
# Delay between completed full bidding-job scans.
BIDDING_SCAN_SLEEP_MS=60000
# Maximum bidding jobs processed concurrently by one bot runtime.
BIDDING_MAX_CONCURRENT_JOBS=1
# Number of bidding jobs bootstrapped in parallel when the bot starts.
BIDDING_BOOTSTRAP_CONCURRENCY=3
# Lifetime assigned to newly placed OpenSea offers, in seconds.
BIDDING_OFFER_EXPIRATION_SECONDS=13920
# How often the bidding bot refreshes collection-offer snapshots from OpenSea.
BIDDING_COLLECTION_OFFERS_POLL_MS=60000
# How long a collection-offer snapshot is considered fresh inside the bot.
BIDDING_COLLECTION_OFFERS_TTL_MS=15000
# Minimum delay between broad collection or trait offer hot-refresh passes.
BIDDING_HOT_REFRESH_BROAD_COOLDOWN_MS=15000
# Minimum delay between exact-token offer hot-refresh passes for the same token.
BIDDING_HOT_REFRESH_ITEM_COOLDOWN_MS=2000
# Minimum delay between bid-book projection writes from bot state.
BIDDING_BID_BOOK_PROJECTION_THROTTLE_MS=15000
# How long backend bid books may trust the bot snapshot before falling back to marketplace orders.
BIDDING_BID_BOOK_SNAPSHOT_STALE_MS=120000
# How often bid books refresh while they are reading regular marketplace orders.
BIDDING_BID_BOOK_NORMAL_LIVE_POLL_MS=10000
# How often bid books refresh while they are reading the active bidding bot snapshot.
BIDDING_BID_BOOK_COMPETITIVE_LIVE_POLL_MS=5000
# How often the bidding bot writes a heartbeat for backend and UI freshness checks.
BIDDING_RUNTIME_HEARTBEAT_INTERVAL_MS=10000
# How old a bot heartbeat may be before bid books stop treating its snapshot as live.
BIDDING_RUNTIME_HEARTBEAT_STALE_MS=30000
# Maximum OpenSea pages scanned when looking up existing offers for a bidding job.
BIDDING_ORDER_LOOKUP_MAX_PAGES=5
# How often the bidding bot scans for DB commands such as pause, resume, or cancel.
BIDDING_COMMAND_POLL_MS=1000
# Maximum DB commands claimed per bidding command reconciliation pass.
BIDDING_COMMAND_BATCH_SIZE=20
# Maximum attempts before a failed bidding command stops retrying.
BIDDING_COMMAND_MAX_ATTEMPTS=5
# How long a claimed bidding command can run before another pass may recover it.
BIDDING_COMMAND_CLAIM_TIMEOUT_MS=300000
# JSON map of collection IDs to traits whose criteria offer snapshots should be refreshed.
BIDDING_CRITERIA_REFRESH_TRAITS_BY_COLLECTION={"terraforms":["Zone","Biome","Level"]}
# JSON map of collection IDs to token traits used to match token bids against criteria offers.
BIDDING_TOKEN_CRITERIA_TRAITS_BY_COLLECTION={"terraforms":["Zone","Biome","Level","Mode"]}
