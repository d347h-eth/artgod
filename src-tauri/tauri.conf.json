{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "ArtGod",
    "version": "0.0.1",
    "identifier": "io.artgod.desktop",
    "build": {
        "frontendDist": "../frontend/dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "yarn workspace @artgod/frontend run dev",
        "beforeBuildCommand": "yarn build:desktop"
    },
    "app": {
        "windows": [
            {
                "title": "ArtGod",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
