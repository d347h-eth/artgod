{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "ArtGod",
    "version": "0.0.1-alpha",
    "identifier": "network.artgod.desktop",
    "build": {
        "frontendDist": "../frontend/dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "yarn workspace @artgod/frontend run dev",
        "beforeBuildCommand": "yarn build:desktop && yarn build:runtime && yarn build:desktop-runtime-resources"
    },
    "app": {
        "windows": [
            {
                "title": "ArtGod",
                "resizable": true,
                "maximized": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": ["resources/runtime"]
    }
}
