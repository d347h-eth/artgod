{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "ArtGod",
    "version": "0.0.1-alpha",
    "identifier": "network.artgod.desktop",
    "build": {
        "frontendDist": "../frontend/dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "node ./scripts/build/dev-frontend-target.mjs admin",
        "beforeBuildCommand": "yarn build:admin && yarn build:userland && yarn build:runtime && yarn build:desktop-runtime-resources"
    },
    "app": {
        "windows": [
            {
                "title": "ArtGod",
                "resizable": true,
                "maximized": false,
                "width": 1000,
                "height": 1000,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": ["resources/runtime"]
    }
}
