# Public origin for the web-hosted instance.
# This value is compiled into the SSR frontend image at build time.
# `PUBLIC_BACKEND_ORIGIN` should match the public Caddy-served site origin.
PUBLIC_SITE_HOST=terraforms.artgod.network
PUBLIC_BACKEND_ORIGIN=https://terraforms.artgod.network
INTERNAL_BACKEND_ORIGIN=http://backend:3000
PUBLIC_EDGE_NETWORK=public-edge
PUBLIC_APP_DEPLOYMENT_MODE=public_single_collection
PUBLIC_APP_CHAIN_REF=ethereum
PUBLIC_APP_COLLECTION_REF=terraforms

# Persist SQLite under the Docker volume mounted at /data.
ARTGOD_DB_PATH=/data/sqlite/main/db

# Backend is reachable publicly only through Caddy/reverse-proxy services on the Docker edge network.
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3000

# Public read routes stay read-only because admin/write routes are not registered in this deployment mode.
# For manual admin, access the DB on the VPS directly for now.
BACKEND_ALLOWED_HOSTS=127.0.0.1,localhost,::1
BACKEND_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
BACKEND_CSRF_COOKIE_SECURE=true
BACKEND_QUERY_CACHE_PROVIDER=memory
BACKEND_PUBLIC_COLLECTION_CACHE_REFRESH_MS=30000
BACKEND_PUBLIC_COLLECTION_PREVIEW_WARM_REFRESH_MS=600000
BACKEND_QUERY_CACHE_TOKEN_PREVIEW_MAX_ENTRIES=250
BACKEND_QUERY_CACHE_TOKEN_PREVIEW_FRESH_MS=600000
BACKEND_QUERY_CACHE_TOKEN_PREVIEW_STALE_MS=1200000
BACKEND_QUERY_CACHE_TOKEN_PREVIEW_WARMUP_CONCURRENCY=3
BACKEND_METRICS_ENABLED=false
BACKEND_METRICS_HOST=0.0.0.0
BACKEND_METRICS_PORT=9480
BACKEND_APM_ENABLED=false
BACKEND_APM_SERVICE_NAMESPACE=artgod.backend
BACKEND_APM_SPAN_PROFILES_ENABLED=true
BACKEND_APM_TRACES_ENABLED=true
BACKEND_APM_PROFILES_ENABLED=true

CHAIN_ID=1
RPC_URL=http://127.0.0.1:8545
# RPC_BACKFILL_URL=
# RPC_WS_URL=ws://127.0.0.1:8546
RPC_RETRY_MAX_ATTEMPTS=5
RPC_RETRY_BASE_DELAY_MS=100
RPC_RETRY_MAX_DELAY_MS=3000
RPC_RATE_LIMIT_REQUESTS_PER_SECOND=50 # use 0 to disable rate limiting
RPC_RATE_LIMIT_BURST=100
RPC_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
RPC_CIRCUIT_BREAKER_OPEN_MS=5000
RPC_CIRCUIT_BREAKER_HALF_OPEN_MAX_REQUESTS=2

NATS_URL=nats://nats:4222
NATS_STREAM_PREFIX=artgod
OFFCHAIN_PERSIST_RAW_OBSERVATIONS=false

WETH_ADDRESS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2
SEAPORT_CONDUIT_CONTROLLER=0x00000000f9490004c11cef243f5400493c00ad63

# OpenSea workers require a real API key.
OPENSEA_API_KEY=
OPENSEA_SNAPSHOT_PAGE_SIZE=100
OPENSEA_RECONCILE_INTERVAL_MS=900000
OPENSEA_STALE_START_THRESHOLD_MS=1800000
OPENSEA_STREAM_SUBSCRIPTION_POLL_MS=5000
OPENSEA_HTTP_RETRY_MAX_ATTEMPTS=3
OPENSEA_HTTP_RETRY_BASE_DELAY_MS=500
OPENSEA_HTTP_RETRY_MAX_DELAY_MS=10000
OPENSEA_HTTP_RETRY_JITTER_RATIO=0.2
OPENSEA_RATE_LIMIT_GET_MAX=4
OPENSEA_RATE_LIMIT_GET_REFILL_PER_SECOND=1
OPENSEA_RATE_LIMIT_POST_MAX=2
OPENSEA_RATE_LIMIT_POST_REFILL_PER_SECOND=0.5

REORG_DEPTH=32
BACKFILL_BATCH_SIZE=50
LOG_CHUNK_SIZE=2000
BOOTSTRAP_SNAPSHOT_BATCH_SIZE=200
BOOTSTRAP_METADATA_BATCH_SIZE=200
BOOTSTRAP_METADATA_CONCURRENCY=8
BOOTSTRAP_METADATA_PROCESS_POLL_MS=5000
BOOTSTRAP_METADATA_RETRY_MAX_ATTEMPTS=5
BOOTSTRAP_METADATA_RETRY_BASE_DELAY_MS=100
BOOTSTRAP_METADATA_RETRY_MAX_DELAY_MS=3000
METADATA_REFRESH_RANGE_CHUNK_SIZE=200

CACHE_MAX_ENTRIES=5000
CACHE_TTL_MS=30000

# Set runtime observability flags to true when starting `docker-compose.deploy.yml` with the `observability` profile.
OBSERVABILITY_OTLP_HTTP_URL=http://tempo:4318/v1/traces
OBSERVABILITY_PYROSCOPE_URL=http://pyroscope:4040
INDEXER_METRICS_ENABLED=false
INDEXER_METRICS_HOST=0.0.0.0
INDEXER_METRICS_PORT_SCHEDULER_WORKER=9464
INDEXER_METRICS_PORT_SYNC_WORKER=9465
INDEXER_METRICS_PORT_REORG_WORKER=9466
INDEXER_METRICS_PORT_DOMAIN_WORKER=9467
INDEXER_METRICS_PORT_OFFCHAIN_INGEST_WORKER=9468
INDEXER_METRICS_PORT_OPENSEA_STREAM_WORKER=9469
INDEXER_METRICS_PORT_BOOTSTRAP_WORKER=9470
INDEXER_METRICS_PORT_DEAD_LETTER_WORKER=9471
INDEXER_METRICS_PORT_OPENSEA_BOOTSTRAP_WORKER=9472
INDEXER_METRICS_PORT_OPENSEA_RECONCILE_WORKER=9473
INDEXER_METRICS_PORT_OPENSEA_RECONCILE_SCHEDULER_WORKER=9474
INDEXER_METRICS_PORT_COLLECTION_EXTENSION_WORKER=9475
INDEXER_APM_ENABLED=false
INDEXER_APM_SERVICE_NAMESPACE=artgod.indexer
INDEXER_APM_SPAN_PROFILES_ENABLED=true
INDEXER_APM_TRACES_ENABLED=true
INDEXER_APM_PROFILES_ENABLED=true

# Grafana is exposed only inside `public-edge` as `artgod-grafana:3000`.
OBSERVABILITY_GRAFANA_ADMIN_USER=admin
OBSERVABILITY_GRAFANA_ADMIN_PASSWORD=change-me-before-exposing
